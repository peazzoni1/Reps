{
  "expo": {
    "name": "Blue Fitness",
    "slug": "blue-fitness",
    "version": "1.4.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "blue-fitness",
    "ios": {
      "buildNumber": "4",
      "supportsTablet": true,
      "bundleIdentifier": "com.bluefitness.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Blue Fitness uses your location to show local weather conditions in your greeting.",
        "NSFaceIDUsageDescription": "Blue Fitness uses Face ID to securely sign you in.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3d7a8a"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4b255837-27d5-4845-bafb-8edbe4fba9d2"
      }
    }
  }
}
